ldrenList:[],hot:c,iconFontClass:a,usable:c,status:"old",openType:g,subMenuCategory:b,menuBelongArea:e}],hot:c,iconFontClass:a,usable:d,status:b,openType:g,subMenuCategory:b,menuBelongArea:e},{id:I,key:G,parentId:w,sort:f,level:h,menuZhDisplayName:"场景方案",description:a,href:j,route:a,childrenList:[{id:k,key:"SolutionPage",parentId:I,sort:l,level:f,menuZhDisplayName:C,description:j,href:"\u002FsolutionPage\u002F648a7c1a8c0c24eb99adc1bf",route:a,childrenList:[],hot:c,iconFontClass:a,usable:d,status:b,openType:g,subMenuCategory:b,menuBelongArea:e}],hot:c,iconFontClass:a,usable:d,status:b,openType:g,subMenuCategory:b,menuBelongArea:e}],_id:"6191bcd400fa24f3b0f84f13",id:w,key:"SupportAndServices",parentId:a,sort:m,level:l,menuZhDisplayName:"支持与服务",description:a,href:j,route:a,hot:c,iconFontClass:a,usable:d,status:b,openType:g,subMenuCategory:b,menuBelongArea:e,information:{image:"支持与服务.png",menuZhDisplayName:"了解支持与服务",href:j,description:"为您提供多样化的服务支持计划与专家咨询，满足您进行业务及对接问题咨询等需求，让合作更加便捷",id:31,key:"SupportAndServicesInfo"}}],consoleMenu:a,activeId:void 0,anchor:a,pendingLogin:{name:a,status:c},downloadFile:a,notice:{_id:"66a1e7ba0edb7fdb6c741d35",startTime:"2025\u002F12\u002F26 17:00",endTime:"2026\u002F01\u002F15 18:00",time:"2025\u002F12\u002F26 18:00",title:"关于“硬件协议在线签约获取”功能下线的公告",content:"\u003Cstyle\u003E.cover .wrap .updateMaintenance{max-width:45rem!important;}\u003C\u002Fstyle\u003E\u003Cdiv style=\"max-height:40vh;overflow:auto;\"\u003E尊敬的用户：\u003Cbr\u002F\u003E感谢您长期以来对海康开放平台的信任与支持！为优化服务体验，平台将对部分功能进行调整，\u003Cstrong\u003E“硬件协议在线签约获取”相关功能即将正式下线\u003C\u002Fstrong\u003E。对此可能给您带来的不便，我们深表歉意，并恳请您的谅解。\u003Cbr\u002F\u003E\u003Cstrong\u003E一、 具体下线内容\u003C\u002Fstrong\u003E\u003Cbr\u002F\u003E本次调整涉及以下两项功能服务：\u003Cbr\u002F\u003E\u003Col style=\"padding:0 34px;\" \u003E\u003Cli style=\"list-style-type:disc;\"\u003E\u003Cstrong\u003E硬件协议在线签约申请流程\u003C\u002Fstrong\u003E\u003C\u002Fli\u003E\u003Cli style=\"list-style-type:disc;\"\u003E\u003Cstrong\u003E个人中心内的“协议管理”功能模块\u003C\u002Fstrong\u003E\u003C\u002Fli\u003E\u003C\u002Fol\u003E\u003Cstrong\u003E二、 功能下线时间安排\u003C\u002Fstrong\u003E\u003Cbr\u002F\u003E为了让您有充足的时间做好准备，功能下线将分阶段进行：\u003Cbr\u002F\u003E\u003Col style=\"padding:0 34px;\"\u003E\u003Cli style=\"list-style-type:disc;\"\u003E\u003Cstrong\u003E第一阶段（自2026年1月15日起）：\u003C\u002Fstrong\u003E 平台将\u003Cstrong\u003E停止创建新的\u003C\u002Fstrong\u003E硬件协议在线签约申请。在此日期前已申请的协议，您仍可登录平台，在“个人中心-协议管理”中\u003Cstrong\u003E正常查看与下载\u003C\u002Fstrong\u003E。\u003C\u002Fli\u003E\u003Cli  style=\"list-style-type:disc;\"\u003E\u003Cstrong\u003E第二阶段（自2026年1月31日起）：\u003C\u002Fstrong\u003E 硬件协议在线签约功能将全面下线。线上平台将不再保留任何相关协议资源，届时将\u003Cstrong\u003E无法再进行查看或下载\u003C\u002Fstrong\u003E。\u003C\u002Fli\u003E\u003C\u002Fol\u003E\u003Cstrong\u003E三、 后续服务指引\u003C\u002Fstrong\u003E\u003Cbr\u002F\u003E功能下线后，如果您仍有获取硬件协议的需求，我们将继续为您提供贴心的线下服务支持：\u003Cbr\u002F\u003E\u003Col style=\"padding:0 34px;\"\u003E\u003Cli style=\"list-style-type:disc;\"\u003E\u003Cstrong\u003E请您通过线下方式，联系您所在地区的海康威视办事处。\u003C\u002Fstrong\u003E我们的专业人员将竭诚协助您处理相关事宜。\u003Cstrong\u003E\u003Ca style=\"color: #00c6c9;\" href=\"https:\u002F\u002Fwww.hikvision.com\u002Fcn\u002FContact\u002FBranch-office\u002F\" target=\"_blank\"\u003E【点击此处查询最近的分支机构信息】\u003C\u002Fa\u003E\u003C\u002Fstrong\u003E\u003C\u002Fli\u003E\u003C\u002Fol\u003E\u003Cstrong\u003E四、 重要提醒与建议\u003C\u002Fstrong\u003E\u003Cbr\u002F\u003E为确保您的业务不受影响，我们强烈建议您：\u003Cbr\u002F\u003E\u003Cstrong\u003E务必在2026年1月31日之前，及时登录平台，下载并妥善存档所有您需要的协议资源。\u003Cstrong\u003E\u003Cbr\u002F\u003E再次感谢您的理解与配合！海康开放平台将持续努力，为您提供更优质的服务。如在操作中遇到任何疑问，欢迎随时通过平台的\u003Ca href=\"https:\u002F\u002Fopen.hikvision.com\u002Ffeedback\" target=\"_blank\" style=\"color: #00c6c9;\"\u003E【意见反馈】\u003C\u002Fa\u003E渠道与我们联系。\u003Cbr\u002F\u003E\u003C\u002Fdiv\u003E",description:j},showHeader:d,online:200,fromPage:a,toPage:a,barComment:c,bottomComment:c,barCommentVisible:c,remarkablePage:a,commentInfo:{},barCommentRect:{},docVersion:j,mustLogin:c,loginVisible:c,loginNotice:c},serverRendered:d}}(null,"normal",false,true,"navigation",3,"currentTab",2,4,"",41,1,5,24,44,"newTab",36,45,10,19,17,32,30,6,"HBP",20,21,"ApplicationOpening","综合安防管理平台",9,"合作伙伴","\u002Fpartner","CustomerSupport",38,40));</script><script src="/305a16248612807edd1b.js" defer></script><script src="/36.0f4db6b2e2eae75d93ca.js" defer></script><script src="/4.33be01d3261ae115a742.js" defer></script><script src="/63.2014f45af58324b3168a.js" defer></script><script src="/65.7b7d306c6bb936fa2d16.js" defer></script><script src="/67.7ea22aad823c73175c2e.js" defer></script><script src="/66.1bf8207ef6b1db1bfec9.js" defer></script><script src="/64.a4927ba8cf760d30b271.js" defer></script><script src="/3.0b5ea62e72552cb2b9b9.js" defer></script><script src="/2.c8e5ece4eb992b0319b6.js" defer></script>
