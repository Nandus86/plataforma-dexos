  <function init="MediaServer_DriveInit" uninit="MediaServer_Fini" start="MediaServer_Start" stop="MediaServer_Stop" msgcb="MediaServer_MsgCallback" error="MediaServer_GetLastError" version="MediaServer_GetVersion" />
</plugin>