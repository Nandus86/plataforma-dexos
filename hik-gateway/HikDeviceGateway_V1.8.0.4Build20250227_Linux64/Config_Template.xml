<?xml version="1.0" encoding="UTF-8" ?>
<Config>
    <BasicInfo>
        <ProductForm>0</ProductForm>
        <Name>Device Gateway</Name>
        <Model>DS-GWAS0101</Model>
        <SoftwareVersion>V1.8.0.201build20250227</SoftwareVersion>
		<WebSessionID></WebSessionID>
    </BasicInfo>
    <Network>
		<AddrList>
            <Addr>
                <V4>
                    <IP>0.0.0.0</IP>
					<ExternalIP>0.0.0.0</ExternalIP>
					<DeviceExternal>0.0.0.0</DeviceExternal>
                </V4>
				<Protocol>ehome/ehome5.0/ISAPI/SDK</Protocol>
            </Addr>
        </AddrList>
        <HTTP>
            <Port>80</Port>
            <Enable>0</Enable>
			<ExternalPort>80</ExternalPort>
        </HTTP>
        <HTTPS>
            <Port>443</Port>
            <Enable>0</Enable>
			<ExternalPort>443</ExternalPort>
        </HTTPS>
        <RTSP>
            <Port>554</Port>
            <Enable>0</Enable>
			<ExternalPort>554</ExternalPort>
        </RTSP>
		<PSS>
  		    <Enable>0</Enable>
		    <Upload>
			    <Port>7091</Port>				
				<ExternalPort>7091</ExternalPort>
			</Upload>
			<Download>
			    <Port>10081</Port>
				<ExternalPort>10081</ExternalPort>
			</Download>
		</PSS>
		<PortMapping>
		    <DeviceEnable>false</DeviceEnable>
			<PlatformEnable>false</PlatformEnable>
			<AlarmPortType>1</AlarmPortType>
			<EhomeReg>
                <Port>7661</Port>
                <ExternalPort>7661</ExternalPort>
            </EhomeReg>
            <EhomeAlarm>
                <Port>7662</Port>
                <ExternalPort>7662</ExternalPort>
            </EhomeAlarm>            
            <EhomeStream>
                <MinPort>15000</MinPort>
				<MaxPort>17000</MaxPort>
                <ExternalMinPort>15000</ExternalMinPort>
				<ExternalMaxPort>17000</ExternalMaxPort>
            </EhomeStream>
			<EhomeV5Reg>
                <Port>7661</Port>
                <ExternalPort>7661</ExternalPort>
            </EhomeV5Reg>
			<EhomeV5Alarm>
                <Port>7662</Port>
                <ExternalPort>7662</ExternalPort>
            </EhomeV5Alarm>
			<EhomeV5VideoAlarm>
                <Port>7663</Port>
                <ExternalPort>7663</ExternalPort>
            </EhomeV5VideoAlarm>
			<EhomeV5Stream>
                <Port>7664</Port>
                <ExternalPort>7664</ExternalPort>
            </EhomeV5Stream>
			<EhomeV5PlayBack>
                <Port>7665</Port>
                <ExternalPort>7665</ExternalPort>
            </EhomeV5PlayBack>
			<EhomeV5TwoWayAudio>
                <Port>7666</Port>
                <ExternalPort>7666</ExternalPort>
            </EhomeV5TwoWayAudio>
			<EhomeV5AcsAlarm>
                <Port>7667</Port>
                <ExternalPort>7667</ExternalPort>
            </EhomeV5AcsAlarm>
		</PortMapping>
		<HeartbeatParam>
			<KeepAliveSeconds>30</KeepAliveSeconds>
			<KeepAliveCount>3</KeepAliveCount>
		</HeartbeatParam>
    </Network>
    <Maintain>
        <Log>
            <Enable>1</Enable>
            <Level>3</Level>
        </Log>
        <LogCleanup>
            <IntervalHour>1</IntervalHour>
            <RetentionDay>200</RetentionDay>
        </LogCleanup>
        <LogDeviceTransparent>0</LogDeviceTransparent>
    </Maintain>
	<NATGateway>
        <PortRangeList>
            <PortRange>
                <Protocol>HTTP</Protocol>
                <min>27000</min>
                <max>27800</max>
            </PortRange>
            <PortRange>
                <Protocol>RTSP</Protocol>
                <min>28000</min>
                <max>28800</max>
            </PortRange>
        </PortRangeList>
    </NATGateway>
    <AlarmMonitor>
	<Enable>0</Enable>
	<token></token>
    </AlarmMonitor>
    <HttpHostNotificationList>
        <HttpHostNotification>
	    <Enable>0</Enable>
	    <IP>127.0.0.1</IP>
	    <Port>7000</Port>
	    <url>/ISAPI/Event/notification/uploadEvent?format=json</url>
        </HttpHostNotification>
    </HttpHostNotificationList>
    <EventSubCfg>
		<Enable>0</Enable>
    </EventSubCfg>
	<IsupListenCfg>
        <Enable>0</Enable>
    </IsupListenCfg>
    <DeviceMgmt>
        <!-- "AC","V"-->
        <Checked>AC</Checked>
    </DeviceMgmt>
	<MetadataCfg>
        <Enable>0</Enable>
    </MetadataCfg>		
</Config>
